# CUA-BUK Monitor One - Template de Produccion
# INSTRUCCIONES:
# 1. Copiar este archivo como .env.production
# 2. Reemplazar todos los valores marcados con CAMBIAR_*
# 3. NUNCA commitear .env.production al repositorio
#
# POLITICA DE ROTACION:
# - JWT_SECRET: rotar cada 90 dias
# - POSTGRES_PASSWORD: rotar cada 180 dias
# - BUK_CLIENT_SECRET: segun politica del proveedor
# - SAP_API_KEY: segun politica SAP
# - AZURE_CLIENT_SECRET: rotar cada 90 dias (Azure AD default)
# - Al rotar, actualizar en el ambiente y reiniciar servicios afectados

# PostgreSQL
POSTGRES_USER=cua_admin
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_POSTGRES_SEGURO
POSTGRES_DB=cua_buk_db
DATABASE_URL=postgresql://cua_admin:CAMBIAR_PASSWORD_POSTGRES_SEGURO@cua-postgres:5432/cua_buk_db

# JWT (generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CAMBIAR_JWT_SECRET_64_CHARS_MIN

# Servicios
NODE_ENV=production
MOCK_MODE=false

# BUK API (obtener de proveedor BUK)
BUK_API_URL=CAMBIAR_URL_API_BUK
BUK_CLIENT_ID=CAMBIAR_CLIENT_ID_BUK
BUK_CLIENT_SECRET=CAMBIAR_CLIENT_SECRET_BUK

# SAP TrakCare (obtener de equipo SAP)
SAP_API_URL=CAMBIAR_URL_SAP_TRAKCARE
SAP_API_KEY=CAMBIAR_API_KEY_SAP
SAP_TIMEOUT=30000

# Azure AD / Microsoft Graph (obtener de TI Microsoft)
AZURE_AD_URL=https://login.microsoftonline.com
AZURE_TENANT_ID=CAMBIAR_TENANT_ID
AZURE_CLIENT_ID=CAMBIAR_CLIENT_ID_AZURE
AZURE_CLIENT_SECRET=CAMBIAR_CLIENT_SECRET_AZURE
