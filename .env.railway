# CUA-BUK Monitor One - Railway Environment Variables
# These need to be configured in Railway dashboard for each service

# === SHARED (all services that use DB) ===
# DATABASE_URL=${{Postgres.DATABASE_URL}}  ← Railway auto-generates this
# NODE_ENV=production

# === srv-usuarios + cua-orq ===
# JWT_SECRET=<generate-a-strong-secret>

# === adp-buk, adp-sap, adp-azuread ===
# MOCK_MODE=true

# === cua-orq (internal networking) ===
# ADP_BUK_URL=http://adp-buk.railway.internal:<PORT>
# ADP_SAP_URL=http://adp-sap.railway.internal:<PORT>
# ADP_AZUREAD_URL=http://adp-azuread.railway.internal:<PORT>
# SRV_CONTRATACION_URL=http://srv-contratacion.railway.internal:<PORT>

# === cua-page (internal networking to backends) ===
# CUA_ORQ_URL=http://cua-orq.railway.internal:<PORT>
# SRV_CONTRATACION_URL=http://srv-contratacion.railway.internal:<PORT>
# SRV_USUARIOS_URL=http://srv-usuarios.railway.internal:<PORT>
# SRV_REPORTES_URL=http://srv-reportes.railway.internal:<PORT>
# ADP_BUK_URL=http://adp-buk.railway.internal:<PORT>
# ADP_SAP_URL=http://adp-sap.railway.internal:<PORT>
# ADP_AZUREAD_URL=http://adp-azuread.railway.internal:<PORT>

# NOTE: Railway injects PORT automatically. Do NOT set it manually.
# NOTE: Replace <PORT> with the actual port each service listens on.
